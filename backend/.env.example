# ============================================================================
# Apex Intel — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit the real `.env` to version control!
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────
APP_NAME=Apex Intel
DEBUG=False

# ── Database ─────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/apex_intel

# ── OpenAI / LLM ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Web Search (Serper.dev) ──────────────────────────────────────────────
SERPER_API_KEY=your-serper-api-key-here

# ── Redis (optional) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Agent Configuration ─────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_RETRIES=2

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (parsed as JSON array by pydantic)
CORS_ORIGINS=["http://localhost:3000"]

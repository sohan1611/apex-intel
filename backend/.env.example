# ============================================================================
# Apex Intel — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit the real `.env` to version control!
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────
APP_NAME="Apex Intel"
DEBUG=False

# ── Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_jwt_key
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Database ─────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/apex_intel

# ── LLM Configuration ───────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_MAX_CONCURRENT_REQUESTS=1  # Use 1 for Gemini Free Tier, 5+ for Paid/OpenAI

# ── Web Search (Serper.dev) ──────────────────────────────────────────────
SERPER_API_KEY=your-serper-api-key-here

# ── Redis (optional) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Agent Configuration ─────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_RETRIES=2

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (parsed as JSON array by pydantic)
CORS_ORIGINS=["http://localhost:3000"]
